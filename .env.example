# ====================================================================
# AI Agent Observatory — ortam değişkenleri ŞABLONU
# Kopyala:  cp .env.example .env   ve değerleri doldur.
# Değişiklikten sonra:  docker compose -f docker-compose.dev.yml up -d --force-recreate backend
#
# ⚠️ ÖNEMLİ: Değerlerin YANINA satır-içi yorum YAZMA (ör. `KEY=  # not`).
# Bazı ayrıştırıcılar boş değerde yorumu değerin parçası sanır → hatalı/çöp değer.
# Yorumları her zaman değişkenin ÜSTÜNE ayrı satıra yaz (bu dosyadaki gibi).
# `.env` ASLA commit'lenmez; `.env.example` commit'lenir.
# ====================================================================

# ─── PostgreSQL ───────────────────────────────────────────
# Ana veritabanı. Prod'da parolayı güçlü/rastgele yap.
POSTGRES_USER=observatory
POSTGRES_PASSWORD=changeme
POSTGRES_DB=observatory

# ─── Redis ────────────────────────────────────────────────
# Önbellek + OAuth state + WebSocket. Docker içinden host adı "redis".
REDIS_URL=redis://redis:6379

# ─── ClickHouse ───────────────────────────────────────────
# Trace/analitik deposu.
CLICKHOUSE_DB=observatory
CLICKHOUSE_USER=observatory
CLICKHOUSE_PASSWORD=changeme

# ─── App ──────────────────────────────────────────────────
# APP_ENV: development | production
APP_ENV=development
# APP_SECRET_KEY: Fernet şifreleme + genel sır (token'ları şifreler).
# Prod'da uzun/rastgele yap; sonradan DEĞİŞTİRME (şifreli veriler okunamaz olur).
APP_SECRET_KEY=changeme-dev-only
# FRONTEND_URL: frontend kök URL (e-posta linkleri + OAuth callback dönüşü)
FRONTEND_URL=http://localhost:3000

# ─── JWT (RS256) — kimlik doğrulama için zorunlu ──────────
# Anahtar çifti üret:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# PEM'i tek satıra çevir (satır sonları \n), çift tırnak içine al: "-----BEGIN...\n...\n-----END...\n"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Token ömürleri: access (dakika) / refresh (gün)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email (Resend) — kayıt/davet/parola e-postaları ─────
# resend.com API anahtarı (yoksa e-posta gönderilmez)
RESEND_API_KEY=
# Gönderen (doğrulanmış domain gerekir)
EMAIL_FROM=AI Observatory <noreply@example.com>

# ─── LLM Providers (platform-level fallback) ──────────────
# Org kendi anahtarını Providers UI'dan girmezse buradakiler kullanılır.
# Kullanmadığını BOŞ bırak.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Yerel Ollama sunucusu
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Custom model (F3) — self-hosted / OpenAI-uyumlu ──────
# provider='custom' ile kendi modelini (ör. gpt-oss-20b) kullanmak için.
# Aynı makine: host.docker.internal · LAN/uzak: IP/hostname · gerekiyorsa URL'e /v1 ekle.
# CUSTOM_BASE_URL boşsa custom devre dışı. Endpoint anahtar istemiyorsa CUSTOM_API_KEY boş kalsın.
CUSTOM_BASE_URL=
CUSTOM_API_KEY=

# ─── Gmail (G1) — Google OAuth ────────────────────────────
# Agent'ların kullanıcı Gmail'ine erişmesi için. Kurulum:
#   1) Google Cloud Console > Credentials > OAuth client (Web application)
#   2) Gmail API'yi etkinleştir; consent screen = External + Testing; kendini Test user ekle
#   3) Authorized redirect URI = GOOGLE_REDIRECT_URI ile BİREBİR aynı olmalı
# Kullanmıyorsan üçünü de boş bırak.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/connections/google/callback

# ─── Agent Tools Helpers ──────────────────────────────────
# Web arama tool'u (web_search) için Tavily anahtarı (tavily.com). Yoksa web arama çalışmaz.
TAVILY_API_KEY=
