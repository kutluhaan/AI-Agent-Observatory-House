# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=observatory
POSTGRES_PASSWORD=changeme
POSTGRES_DB=observatory

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── ClickHouse ───────────────────────────────────────────
CLICKHOUSE_DB=observatory
CLICKHOUSE_USER=observatory
CLICKHOUSE_PASSWORD=changeme

# ─── JWT (RS256) ──────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ──────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=changeme-use-strong-secret-in-production
FRONTEND_URL=http://localhost:3000

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# ─── LLM Providers ────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
OLLAMA_BASE_URL=http://host.docker.internal:11434
