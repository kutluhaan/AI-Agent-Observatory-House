# ====================================================================
# AI Agent Observatory — ortam değişkenleri ŞABLONU
# Bu dosyayı `.env` olarak kopyala ve değerleri doldur:  cp .env.example .env
# Backend bunları docker-compose `env_file` ile okur. Değişiklikten sonra:
#   docker compose -f docker-compose.dev.yml up -d --force-recreate backend
# `.env` ASLA commit'lenmez (gizli anahtarlar içerir); `.env.example` commit'lenir.
# ====================================================================

# ─── PostgreSQL ───────────────────────────────────────────
# Ana veritabanı (agent, test, ekip, bağlantılar). Docker bu değerlerle kurar.
POSTGRES_USER=observatory             # DB kullanıcı adı
POSTGRES_PASSWORD=changeme            # DB parolası — prod'da güçlü/rastgele yap
POSTGRES_DB=observatory               # DB adı

# ─── Redis ────────────────────────────────────────────────
# Önbellek + OAuth state + WebSocket. Docker içinden host adı "redis".
REDIS_URL=redis://redis:6379

# ─── ClickHouse ───────────────────────────────────────────
# Trace/analitik deposu (yüksek hacimli olay verisi).
CLICKHOUSE_DB=observatory             # ClickHouse DB adı
CLICKHOUSE_USER=observatory           # ClickHouse kullanıcı
CLICKHOUSE_PASSWORD=changeme          # ClickHouse parolası

# ─── App ──────────────────────────────────────────────────
APP_ENV=development                   # development | production
APP_SECRET_KEY=changeme-dev-only      # Fernet şifreleme + genel sır (provider/OAuth token'larını şifreler).
                                      # ÖNEMLİ: prod'da uzun/rastgele yap; sonradan DEĞİŞTİRME (şifreli veriler okunamaz olur).
FRONTEND_URL=http://localhost:3000    # Frontend kök URL (e-posta linkleri + OAuth callback dönüşü)

# ─── JWT (RS256) — kimlik doğrulama için zorunlu ──────────
# Anahtar çifti üret:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# PEM'i tek satıra çevir (satır sonları \n), çift tırnak içine al: "-----BEGIN...\n...\n-----END...\n"
JWT_PRIVATE_KEY=                      # Token imzalama anahtarı (GİZLİ)
JWT_PUBLIC_KEY=                       # Token doğrulama anahtarı
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15    # Access token ömrü (dakika)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7       # Refresh token ömrü (gün)

# ─── Email (Resend) — kayıt/davet/parola e-postaları ─────
RESEND_API_KEY=                       # resend.com API anahtarı (yoksa e-posta gönderilmez)
EMAIL_FROM=AI Observatory <noreply@example.com>   # Gönderen (doğrulanmış domain gerekir)

# ─── LLM Providers (platform-level fallback) ──────────────
# Org kendi anahtarını Providers UI'dan girmezse buradakiler kullanılır. Kullanmadığını boş bırak.
OPENAI_API_KEY=                       # OpenAI API anahtarı
ANTHROPIC_API_KEY=                    # Anthropic (Claude) API anahtarı
GEMINI_API_KEY=                       # Google Gemini API anahtarı
OLLAMA_BASE_URL=http://host.docker.internal:11434   # Yerel Ollama sunucusu

# ─── Custom model (F3) — self-hosted / OpenAI-uyumlu ──────
# provider='custom' ile kendi modelini (ör. gpt-oss-20b) kullanmak için.
# Aynı makine: host.docker.internal · LAN/uzak: IP/hostname · gerekiyorsa URL'e /v1 ekle.
CUSTOM_BASE_URL=                      # OpenAI-uyumlu kök URL (boş = devre dışı)
CUSTOM_API_KEY=                       # Endpoint anahtar istiyorsa; istemiyorsa boş

# ─── Gmail (G1) — Google OAuth ────────────────────────────
# Agent'ların kullanıcı Gmail'ine erişmesi için (ara/oku/gönder). Kurulum:
#   1) Google Cloud Console > Credentials > OAuth client (Web application)
#   2) Gmail API'yi etkinleştir; consent screen = External + Testing; kendini Test user ekle
#   3) Authorized redirect URI = GOOGLE_REDIRECT_URI ile BİREBİR aynı olmalı
# Kullanmıyorsan üçünü de boş bırak.
GOOGLE_CLIENT_ID=                     # OAuth Client ID
GOOGLE_CLIENT_SECRET=                 # OAuth Client Secret (GİZLİ)
GOOGLE_REDIRECT_URI=http://localhost:8000/connections/google/callback   # Backend callback (Google'daki ile aynı)

# ─── Agent Tools Helpers ──────────────────────────────────
# Web arama tool'u (web_search) için Tavily anahtarı (tavily.com). Yoksa web arama çalışmaz.
TAVILY_API_KEY=
