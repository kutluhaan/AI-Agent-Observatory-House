# Docker Compose — Postgres
POSTGRES_USER=observatory
POSTGRES_PASSWORD=changeme
POSTGRES_DB=observatory

# Docker Compose — ClickHouse
CLICKHOUSE_DB=observatory
CLICKHOUSE_USER=observatory
CLICKHOUSE_PASSWORD=changeme

# App
APP_ENV=development
APP_SECRET_KEY=changeme-dev-only
FRONTEND_URL=http://localhost:3000

# JWT (RS256) — required for auth; generate keys: docs/spec/m3-auth-core.md
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Email (Resend) — M4 verification emails
RESEND_API_KEY=
EMAIL_FROM=AI Observatory <noreply@example.com>

# LLM providers (M7+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Self-hosted / OpenAI-compatible custom model (F3) — e.g. gpt-oss-20b.
# Same machine: use host.docker.internal; LAN/remote: use IP/hostname.
# Leave CUSTOM_API_KEY empty if the endpoint needs no key.
CUSTOM_BASE_URL=
CUSTOM_API_KEY=

# Research agent (M12) — get key at https://tavily.com
TAVILY_API_KEY=
